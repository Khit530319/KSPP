{
  "name": "freshcut-erp-backend",
  "version": "1.0.0",
  "description": "FreshCut ERP Backend API",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed":    "psql $DATABASE_URL -f src/db/schema.sql"
  },
  "dependencies": {
    "express":        "^4.18.2",
    "pg":             "^8.11.3",
    "bcryptjs":       "^2.4.3",
    "jsonwebtoken":   "^9.0.2",
    "cors":           "^2.8.5",
    "dotenv":         "^16.3.1",
    "multer":         "^1.4.5-lts.1",
    "express-rate-limit": "^7.1.5",
    "helmet":         "^7.1.0",
    "morgan":         "^1.10.0",
    "uuid":           "^9.0.0",
    "xlsx":           "^0.18.5",
    "pdf-parse":      "^1.1.1",
    "ws":             "^8.14.2",
    "date-fns":       "^3.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
